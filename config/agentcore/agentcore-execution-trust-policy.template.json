{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AssumeRolePolicy",
      "Effect": "Allow",
      "Principal": {
        "Service": "bedrock-agentcore.amazonaws.com"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "__AWS_ACCOUNT_ID__"
        },
        "ArnLike": {
          "aws:SourceArn": "arn:aws:bedrock-agentcore:__AWS_REGION__:__AWS_ACCOUNT_ID__:*"
        }
      }
    }
  ]
}
