ANTHROPIC_API_KEY=your-api-key
API_HOST=127.0.0.1
API_PORT=8000
UI_HOST=127.0.0.1
UI_PORT=5001
BACKEND_URL=http://127.0.0.1:8000
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
# Optional. If omitted, the app derives an internal secret automatically.
AUTH_SECRET=
CLAUDE_CLI_PATH=claude
LOCAL_INSIGHTS_MCP_ENABLED=true
GITHUB_MCP_ENABLED=false
GITHUB_TOKEN=
GITHUB_MCP_COMMAND=npx
GITHUB_MCP_ARGS=-y @modelcontextprotocol/server-github
REMOTE_MCP_ENABLED=false
REMOTE_MCP_NAME=external-delivery-api
REMOTE_MCP_TYPE=http
REMOTE_MCP_URL=
REMOTE_MCP_AUTH_HEADER=Authorization
REMOTE_MCP_BEARER_TOKEN=
