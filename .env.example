# — Required ———————————————————————————————————————————————
AWS_REGION=us-east-1
CLAUDE_CODE_USE_BEDROCK=1
ANTHROPIC_MODEL=global.anthropic.claude-sonnet-4-5-20250929-v1:0
ANTHROPIC_SMALL_FAST_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0

# — Required for AgentCore deployment ——————————————————————
AGENTCORE_EXECUTION_ROLE_NAME=AgentCoreRuntimeExecutionRole
# Required only if the deploy script needs to create the AgentCore/CodeBuild source bucket:
# AWS_ACCOUNT_ID=AWS_ACCOUNT_ID
# AWS_TAG_CREATEDBY=YOUR_EMAIL_ID
# AWS_TAG_PURPOSE=YOUR_TAG_PURPOSE
# AWS_TAG_PROJECT=YOUR_PROJECT_NAME
# AWS_TAG_ENVIRONMENT=YOUR_ENVIRONMENT
# AWS_TAG_OWNER=PO/PM_EMAIL_ID
# AWS_TAG_EXPIRYDATE=DD-MM-YYYY

# — Optional deploy overrides ———————————————————————————————
# AGENTCORE_AGENT_NAME=your_agent_name
# AGENTCORE_ENTRYPOINT=main.py
# AGENTCORE_PYTHON_BASE_IMAGE=public.ecr.aws/docker/library/python:3.13-slim
# AGENTCORE_EXECUTION_ROLE_ARN=arn:aws:iam::<account-id>:role/<agentcore-execution-role>
# AGENTCORE_MEMORY_MODE=STM_ONLY

# — Tool selection (comma-separated, leave empty for no external tools) —
# Available: athena, knowledge_base, s3
AGENT_TOOLS=knowledge_base,s3

# — Athena tool (required when AGENT_TOOLS includes 'athena') ————————
# ATHENA_DATABASE=your_database
# ATHENA_OUTPUT_LOCATION=s3://your-bucket/athena-results/

# — Bedrock Knowledge Base tool (required when AGENT_TOOLS includes 'knowledge_base') —
# KNOWLEDGE_BASE_ID=ABCDE12345
# KB_MAX_RESULTS=5

# — S3 read location —
S3_READ_BUCKET=shared-agent-bucket
# S3_READ_PREFIX=optional/path/prefix/
# Set S3_WRITE_BUCKET to enable primary S3 request storage at agents/<agent_name>/results/<request_id>/...
# S3_WRITE_BUCKET=agent-output-bucket
S3_MAX_LIST_RESULTS=100
S3_MAX_OBJECT_BYTES=1048576
